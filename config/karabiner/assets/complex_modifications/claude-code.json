{
	"title": "Claude Code for VSCode",
	"rules": [
		{
			"description": "Ctrl+p,n,b,f to arrow key for VSCode",
			"manipulators": [
				{
					"type": "basic",
					"from": {
						"key_code": "p",
						"modifiers": {
							"mandatory": ["control"]
						}
					},
					"to": [
						{
							"key_code": "up_arrow"
						}
					],
					"conditions": [
						{
							"type": "frontmost_application_if",
							"bundle_identifiers": [
								"^com\\.microsoft\\.VSCode$",
								"^dev\\.kiro\\.desktop$",
								"^com\\.todesktop\\.230313mzl4w4u92$",
                "^com\\.google\\.antigravity$"
							]
						}
					]
				},
				{
					"type": "basic",
					"from": {
						"key_code": "n",
						"modifiers": {
							"mandatory": ["control"]
						}
					},
					"to": [
						{
							"key_code": "down_arrow"
						}
					],
          "conditions": [
						{
							"type": "frontmost_application_if",
							"bundle_identifiers": [
								"^com\\.microsoft\\.VSCode$",
								"^dev\\.kiro\\.desktop$",
								"^com\\.todesktop\\.230313mzl4w4u92$",
                "^com\\.google\\.antigravity$"
							]
						}
					]
				},
        {
					"type": "basic",
					"from": {
						"key_code": "b",
						"modifiers": {
							"mandatory": ["control"]
						}
					},
					"to": [
						{
							"key_code": "left_arrow"
						}
					],
          "conditions": [
						{
							"type": "frontmost_application_if",
							"bundle_identifiers": [
								"^com\\.microsoft\\.VSCode$",
								"^dev\\.kiro\\.desktop$",
								"^com\\.todesktop\\.230313mzl4w4u92$",
                "^com\\.google\\.antigravity$"
							]
						}
					]
				},
        {
					"type": "basic",
					"from": {
						"key_code": "f",
						"modifiers": {
							"mandatory": ["control"]
						}
					},
					"to": [
						{
							"key_code": "right_arrow"
						}
					],
          "conditions": [
						{
							"type": "frontmost_application_if",
							"bundle_identifiers": [
								"^com\\.microsoft\\.VSCode$",
								"^dev\\.kiro\\.desktop$",
								"^com\\.todesktop\\.230313mzl4w4u92$",
                "^com\\.google\\.antigravity$"
							]
						}
					]
				}
			]
		}
	]
}
