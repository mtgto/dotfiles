[alias]
	st = status
	ci = commit
	co = checkout
	br = branch

[include]
	path = ~/.gitconfig.local
[core]
	excludesfile = ~/.config/git/ignore
	pager = less -iMRFX
[init]
	templatedir = ~/.config/git/templates
	defaultBranch = main
[pull]
	rebase = true
	autostash = true
[rebase]
	autostash = true
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
